# PDF Translator — Environment Configuration
# cp .env.example .env  then fill in your values

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=change-me-to-a-long-random-string-in-production
PORT=5000

# ── LLM API Keys (set only the providers you use) ────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ── Translation defaults ──────────────────────────────────────────────────────
DEFAULT_PROVIDER=claude        # claude | openai | gemini | grok | groq | mistral | ollama
MAX_WORKERS=6                  # parallel page threads per job
CHUNK_SIZE=20                  # text spans per LLM call

# ── Limits ────────────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=100
JOB_TTL_HOURS=4
MAX_CONCURRENT_JOBS=20

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATELIMIT_ENABLED=true
RATELIMIT_DEFAULT=200/hour
RATELIMIT_TRANSLATE=20/hour

# ── Infrastructure ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Gunicorn ──────────────────────────────────────────────────────────────────
GUNICORN_WORKERS=4
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=600

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=*                 # e.g. https://yourdomain.com,https://app.yourdomain.com

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
